# App
PORT=3000
APP_BASE_URL=http://localhost:3000
COOKIE_SECURE=false
SUBSTACK_COOKIE=
SUBSTACK_COOKIE_HOSTS=

# Auth (header-trust)
#
# KindleFlow trusts the X-Auth-Request-Email header from an upstream reverse
# proxy (Tinyauth / Caddy / Cloudflare Access). The container MUST only be
# reachable through that proxy.
#
# For local dev without a proxy, set AUTH_DEV_BYPASS=true and NODE_ENV in
# {development,test}. Production refuses to start with AUTH_DEV_BYPASS=true.
AUTH_DEV_BYPASS=false
AUTH_DEV_EMAIL=dev@kindleflow.local
#
# Optional: when set, every header-auth request must also carry a matching
# X-Auth-Request-Proxy-Secret header (set by your reverse proxy). Recommended
# in production as defense-in-depth against direct hits.
AUTH_TRUSTED_PROXY_SECRET=

# Optional Tailscale sidecar for https://kindleflow.<tailnet>.ts.net
COMPOSE_PROFILES=tailscale
TS_AUTHKEY=
TAILSCALE_STATE_DIR=./tailscale/state
TAILSCALE_CONFIG_DIR=./tailscale/config

# Gmail SMTP example. Used only for Kindle delivery (no login emails).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-address@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=your-address@gmail.com
