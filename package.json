{
  "name": "kindleflow",
  "version": "1.0.0",
  "description": "Self-hosted article-to-Kindle web app",
  "private": true,
  "main": "server/index.ts",
  "scripts": {
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite --host 0.0.0.0",
    "test": "vitest run",
    "build": "tsc --noEmit && vite build",
    "build:cli": "tsc -p tsconfig.cli.json",
    "build:mcp": "tsc -p tsconfig.mcp.json",
    "generate:extension-store-assets": "node scripts/generate-extension-store-assets.mjs",
    "package:extension": "node scripts/package-extension.mjs",
    "start": "tsx server/index.ts"
  },
  "bin": {
    "kindleflow": "dist/cli/cli/index.js",
    "kindleflow-mcp": "dist/mcp/mcp/server.js"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/static": "^9.1.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "@types/pdf-parse": "^1.1.5",
    "commander": "^14.0.3",
    "epub-gen-memory": "^1.1.2",
    "fastify": "^5.8.5",
    "jsdom": "^29.1.0",
    "nodemailer": "^8.0.7",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "sanitize-html": "^2.17.3",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
